Bootstrap: docker
From: ubuntu:22.04

%environment
    export PATH="/root/miniconda3/bin:$PATH"
    export DEBIAN_FRONTEND=noninteractive
    export OMP_NUM_THREADS=2
    export QT_QPA_PLATFORM=offscreen

%post
    # Basic system tools
    apt-get update && apt-get install -y \
        wget curl git build-essential unzip make \
        && apt-get clean

    # Install Miniconda
    wget https://repo.anaconda.com/miniconda/Miniconda3-latest-Linux-x86_64.sh -O miniconda.sh
    bash miniconda.sh -b -p /root/miniconda3
    rm miniconda.sh

    # Use conda's python and install Poetry
    export PATH="/root/miniconda3/bin:$PATH"
    conda install -y python=3.12
    curl -sSL https://install.python-poetry.org | POETRY_VERSION=1.7.0 python3 -

    # Install Python runtime required by SandboxFusion
    cd /root/sandbox/runtime/python
    bash install-python-runtime.sh

    # Install Python dependencies
    cd /root/sandbox
    poetry config virtualenvs.create false
    touch /root/miniconda3/pyvenv.cfg  # workaround for poetry bug
    poetry install

%files
    . /root/sandbox

%runscript
    cd /root/sandbox
    exec make run-online
